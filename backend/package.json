{
  "name": "koraa-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seeds/index.ts",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --ci --forceExit",
    "coverage": "jest --coverage --forceExit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"jest.setup.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"jest.setup.ts\"",
    "typecheck": "tsc --noEmit",
    "unused": "knip"
  },
  "dependencies": {
    "@getbrevo/brevo": "^5.0.3",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "nanoid": "^5.1.7",
    "nodemailer": "^8.0.4",
    "pg": "^8.11.5",
    "zod": "^3.23.8"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.12.12",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "knip": "^5.0.0",
    "prettier": "^3.2.5",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0"
  }
}
